local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")

local TackleEvent = ReplicatedStorage:WaitForChild("TackleEvent")

-- CONFIG
local TACKLE_RANGE = 6
local RAGDOLL_TIME = 3
local BALL_REATTACH_DELAY = 0.8 
local BALL_FORWARD_OFFSET = 3
local BALL_DOWN_OFFSET = -1
local BALL_PUSH_FORCE = 18

local function ragdollCharacter(character, duration)
	local humanoid = character:FindFirstChild("Humanoid")
	if not humanoid then return end

	humanoid:ChangeState(Enum.HumanoidStateType.Physics)
	humanoid.AutoRotate = false

	local motors = {}

	for _, motor in ipairs(character:GetDescendants()) do
		if motor:IsA("Motor6D") then
			table.insert(motors, motor)

			local a0 = Instance.new("Attachment")
			local a1 = Instance.new("Attachment")
			a0.CFrame = motor.C0
			a1.CFrame = motor.C1
			a0.Parent = motor.Part0
			a1.Parent = motor.Part1

			local socket = Instance.new("BallSocketConstraint")
			socket.Attachment0 = a0
			socket.Attachment1 = a1
			socket.Parent = motor.Part0

			motor.Enabled = false
		end
	end

	task.delay(duration, function()
		for _, obj in ipairs(character:GetDescendants()) do
			if obj:IsA("BallSocketConstraint") or obj:IsA("Attachment") then
				obj:Destroy()
			end
		end

		for _, motor in ipairs(motors) do
			if motor then motor.Enabled = true end
		end

		humanoid.AutoRotate = true
		humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
	end)
end

TackleEvent.OnServerEvent:Connect(function(player)
	local char = player.Character
	if not char then return end

	local hrp = char:FindFirstChild("HumanoidRootPart")
	if not hrp then return end

	local ball
	local closest = TACKLE_RANGE

	for _, obj in ipairs(workspace:GetDescendants()) do
		if obj:IsA("BasePart") and obj.Name == "Ball" and not obj.Anchored then
			local dist = (obj.Position - hrp.Position).Magnitude
			if dist < closest then
				closest = dist
				ball = obj
			end
		end
	end

	local tackledCharacter
	for _, other in ipairs(Players:GetPlayers()) do
		if other ~= player and other.Character then
			local otherHRP = other.Character:FindFirstChild("HumanoidRootPart")
			if otherHRP and (otherHRP.Position - hrp.Position).Magnitude < TACKLE_RANGE then
				tackledCharacter = other.Character
				break
			end
		end
	end

	local successfulTackle = tackledCharacter ~= nil

	if tackledCharacter then
		ragdollCharacter(tackledCharacter, RAGDOLL_TIME)
	end

	if not ball then return end

	local canFollow = ball:FindFirstChild("CanFollow")
	if canFollow then
		canFollow.Value = false
	end
	ball:SetAttribute("Detach", true)
	ball:SetNetworkOwner(nil)

	if successfulTackle then
		local targetPos =
			hrp.Position
			+ hrp.CFrame.LookVector * BALL_FORWARD_OFFSET
			+ Vector3.new(0, BALL_DOWN_OFFSET, 0)

		ball.CFrame = CFrame.new(targetPos)

		ball.AssemblyLinearVelocity =
			hrp.CFrame.LookVector * BALL_PUSH_FORCE
	else
		ball.AssemblyLinearVelocity =
			hrp.CFrame.LookVector * 10 + Vector3.new(0, 6, 0)
	end
	task.delay(BALL_REATTACH_DELAY, function()
		if canFollow then
			canFollow.Value = true
		end
	end)
end)
